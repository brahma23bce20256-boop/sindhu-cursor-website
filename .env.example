# Site URL (used for SEO, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://sindhu-restaurant.com

# CMS provider: "file" (default) or "sanity"
CMS_PROVIDER=file

# Optional: email notifications via Resend (https://resend.com)
# RESEND_API_KEY=re_xxxxxxxx
# NOTIFICATION_EMAIL=owner@sindhu.com
# EMAIL_FROM=Sindhu <reservations@sindhu.com>

# Sanity CMS (when CMS_PROVIDER=sanity)
# SANITY_PROJECT_ID=
# SANITY_DATASET=production
# SANITY_API_TOKEN=
